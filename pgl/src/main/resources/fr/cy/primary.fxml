<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Slider?>

<BorderPane fx:id="root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fr.cy.controller.PrimaryController"
            style="-fx-background-color: #0F0F1A;">

    <!-- Barre de titre -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #0A0A14;
                     -fx-padding: 12 20;
                     -fx-border-color: #5B7FFF;
                     -fx-border-width: 0 0 2 0;">
            <Label text="SIMULATION D'ÉVACUATION"
                   style="-fx-text-fill: white;
                          -fx-font-size: 17;
                          -fx-font-weight: bold;"/>
            <Label text=" — PGL GI3A"
                   style="-fx-text-fill: #5B7FFF;
                          -fx-font-size: 13;"/>
        </HBox>
    </top>

    <!-- Zone graphe — remplit tout l'espace central -->
    <center>
        <Pane fx:id="graphContainer"
              style="-fx-background-color: #0F0F1A;"/>
    </center>

    <!-- Barre de contrôle -->
    <bottom>
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: #0A0A14;
                     -fx-padding: 10 20;
                     -fx-border-color: #5B7FFF;
                     -fx-border-width: 2 0 0 0;">

            <Button fx:id="playPauseButton" text="▶  Play" onAction="#onPlayPause"
                    style="-fx-background-color: #2ECC71;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-font-size: 12;
                           -fx-padding: 6 16;
                           -fx-background-radius: 6;
                           -fx-cursor: hand;"/>

            <Button fx:id="stepButton" text="⏭  Step" onAction="#onStep"
                    style="-fx-background-color: #3498DB;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-font-size: 12;
                           -fx-padding: 6 16;
                           -fx-background-radius: 6;
                           -fx-cursor: hand;"/>

            <Button fx:id="resetButton" text="↺  Reset" onAction="#onReset"
                    style="-fx-background-color: #E74C3C;
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-font-size: 12;
                           -fx-padding: 6 16;
                           -fx-background-radius: 6;
                           -fx-cursor: hand;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Label text="TICK"
                   style="-fx-text-fill: #5B7FFF; -fx-font-size: 10; -fx-font-weight: bold;"/>
            <Label fx:id="tickLabel" text="0"
                   style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;"/>

            <Label text="   VITESSE"
                   style="-fx-text-fill: #5B7FFF; -fx-font-size: 10; -fx-font-weight: bold;"/>
            <Slider fx:id="speedSlider"
                    min="0.25" max="4" value="1"
                    prefWidth="130"
                    showTickLabels="true" showTickMarks="true"
                    majorTickUnit="1"/>
            <Label fx:id="speedLabel" text="x1.0"
                   style="-fx-text-fill: white; -fx-font-size: 12; -fx-font-weight: bold;"/>

        </HBox>
    </bottom>

</BorderPane>
